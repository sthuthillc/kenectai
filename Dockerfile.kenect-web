# kenectai.com apex — static landing page (site/). The Studio UI this used
# to serve is a local dev tool: it needs the studio-server preview backend,
# so hosting it statically just shows a permanent "waiting for preview
# server" shell. Serve the marketing page instead; Studio stays local via
# `kenectai preview`.
FROM nginx:1.27-alpine
COPY site/ /usr/share/nginx/html/
COPY nginx.kenect-web.conf /etc/nginx/conf.d/default.conf
EXPOSE 8080
